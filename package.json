{
  "name": "estelarbot",
  "version": "2.0.0",
  "description": "Bot de Minecraft 24/7 ultra-realista para servidor Estelar (PaperMC 1.21.x)",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "start:pm2": "pm2 start dist/index.js --name EstelarBot --restart-delay=5000",
    "logs": "pm2 logs EstelarBot",
    "clean": "rm -rf dist"
  },
  "keywords": ["minecraft", "mineflayer", "bot", "estelar"],
  "author": "EstelarBot",
  "license": "MIT",
  "dependencies": {
    "mineflayer": "^4.23.0",
    "mineflayer-pathfinder": "^2.4.5",
    "mineflayer-pvp": "^1.3.2",
    "mineflayer-auto-eat": "^6.0.1",
    "mineflayer-armor-manager": "^2.0.1",
    "mineflayer-collect-block": "^1.4.1",
    "vec3": "^0.1.10",
    "dotenv": "^16.4.5",
    "axios": "^1.7.2",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0",
    "prismarine-item": "^1.15.0",
    "prismarine-entity": "^1.3.4"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "@types/node": "^20.14.2",
    "ts-node": "^10.9.2"
  }
}
